generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  PROCESSING
  DONE
  FAILED
  CANCELED
}

enum AssetType {
  FACE
  REFERENCE
  RESULT
}

enum CreditTransactionType {
  TOPUP
  SPEND
  REFUND
  ADMIN_ADJUSTMENT
  WELCOME_BONUS
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
}

enum ShowcaseKind {
  READY
  CUSTOM
}

enum GenerationMode {
  READY
  REFERENCE
  EDIT
}

model User {
  id                      String              @id @default(cuid())
  email                   String              @unique
  login                   String              @unique
  passwordHash            String
  role                    UserRole            @default(USER)
  creditBalance           Int                 @default(0)
  isActive                Boolean             @default(true)
  welcomeOfferEndsAt      DateTime?
  businessOfferTriggeredAt DateTime?
  businessOfferEndsAt     DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  orders                  Order[]
  payments                Payment[]
  creditTransactions      CreditTransaction[]
  showcaseItems           ShowcaseItem[]      @relation("ShowcaseItemCreatedBy")
}

model AuthThrottle {
  key            String    @id
  scope          String
  attempts       Int       @default(0)
  firstAttemptAt DateTime  @default(now())
  lastAttemptAt  DateTime  @default(now())
  blockedUntil   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([scope, blockedUntil])
  @@index([scope, lastAttemptAt])
}

model ShowcaseCategory {
  id            String               @id @default(cuid())
  name          String
  slug          String               @unique
  sortOrder     Int                  @default(0)
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  subcategories ShowcaseSubcategory[]
  items         ShowcaseItem[]
}

model ShowcaseSubcategory {
  id         String           @id @default(cuid())
  categoryId String
  category   ShowcaseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  name       String
  slug       String
  sortOrder  Int              @default(0)
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  items      ShowcaseItem[]

  @@unique([categoryId, slug])
  @@index([categoryId, sortOrder])
}

model ShowcaseItem {
  id                     String               @id @default(cuid())
  title                  String
  slug                   String               @unique
  kind                   ShowcaseKind
  description            String?
  promptTemplate         String?
  generationPriceCredits Int?
  coverImageUrl          String
  sortOrder              Int                  @default(0)
  isActive               Boolean              @default(true)

  categoryId             String
  category               ShowcaseCategory     @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  subcategoryId          String?
  subcategory            ShowcaseSubcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)

  createdByUserId        String?
  createdByUser          User?                @relation("ShowcaseItemCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  orders                 Order[]

  @@index([kind, isActive, sortOrder])
  @@index([categoryId, isActive, sortOrder])
  @@index([subcategoryId, isActive, sortOrder])
}

model Order {
  id                 String               @id @default(cuid())
  userId             String
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  showcaseItemId     String?
  showcaseItem       ShowcaseItem?        @relation(fields: [showcaseItemId], references: [id], onDelete: SetNull)

  mode               GenerationMode       @default(READY)
  title              String?
  goal               String?
  status             OrderStatus          @default(DRAFT)

  selectedFormat     String?
  selectedMood       String?
  notes              String?

  promptInput        String?
  promptFinal        String?
  errorMessage       String?
  shareId            String?              @unique @default(cuid())

  creditsSpent       Int                  @default(0)
  priceRub           Int?
  currency           String               @default("RUB")

  paidAt             DateTime?
  startedAt          DateTime?
  finishedAt         DateTime?

  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  assets             OrderAsset[]
  payments           Payment[]
  creditTransactions CreditTransaction[]
}

model OrderAsset {
  id          String    @id @default(cuid())
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  type        AssetType
  url         String
  storageKey  String?
  publicUrl   String?
  fileName    String?
  fileSize    Int?
  mimeType    String?
  width       Int?
  height      Int?
  personIndex Int?
  sortOrder   Int       @default(0)

  createdAt   DateTime  @default(now())

  @@index([orderId, type, sortOrder])
  @@index([orderId, type, personIndex])
}

model Payment {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  orderId           String?
  order             Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)

  provider          String
  externalPaymentId String?       @unique
  amountRub         Int
  creditsPurchased  Int?
  status            PaymentStatus @default(PENDING)
  paidAt            DateTime?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model CreditTransaction {
  id           String                @id @default(cuid())
  userId       String
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  orderId      String?
  order        Order?                @relation(fields: [orderId], references: [id], onDelete: SetNull)

  type         CreditTransactionType
  amount       Int
  balanceAfter Int
  description  String?

  createdAt    DateTime              @default(now())
}
